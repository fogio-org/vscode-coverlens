{
  "name": "coverlens",
  "displayName": "CoverLens",
  "description": "Three-state coverage lens with diff mode and monorepo support",
  "version": "1.0.1",
  "publisher": "fogio",
  "icon": "assets/icon.png",
  "engines": {
    "vscode": "^1.110.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fogio-org/vscode-coverlens"
  },
  "homepage": "https://github.com/fogio-org/vscode-coverlens",
  "bugs": {
    "url": "https://github.com/fogio-org/vscode-coverlens/issues",
    "email": "team@fogio.org"
  },
  "categories": [
    "Testing"
  ],
  "keywords": [
    "coverage",
    "lcov",
    "test",
    "monorepo",
    "diff"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "coverlens.toggle",
        "title": "CoverLens: Toggle Coverage",
        "icon": "$(eye)"
      },
      {
        "command": "coverlens.toggleDiff",
        "title": "CoverLens: Toggle Diff Mode (changed lines only)",
        "icon": "$(git-pull-request)"
      },
      {
        "command": "coverlens.runWithCoverage",
        "title": "CoverLens: Run Tests with Coverage",
        "icon": "$(play)"
      },
      {
        "command": "coverlens.refresh",
        "title": "CoverLens: Reload Coverage Files",
        "icon": "$(refresh)"
      },
      {
        "command": "coverlens.showHistory",
        "title": "CoverLens: Show Coverage Summary",
        "icon": "$(graph)"
      },
      {
        "command": "coverlens.clearHistory",
        "title": "CoverLens: Reset Coverage Baseline"
      },
      {
        "command": "coverlens.stopTests",
        "title": "CoverLens: Stop Running Tests",
        "icon": "$(debug-stop)"
      }
    ],
    "views": {
      "test": [
        {
          "id": "coverlens.tree",
          "name": "Coverage",
          "icon": "$(shield)",
          "contextualTitle": "CoverLens"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "coverlens.toggle",
          "when": "view == coverlens.tree",
          "group": "navigation"
        },
        {
          "command": "coverlens.toggleDiff",
          "when": "view == coverlens.tree",
          "group": "navigation"
        },
        {
          "command": "coverlens.runWithCoverage",
          "when": "view == coverlens.tree",
          "group": "navigation"
        },
        {
          "command": "coverlens.refresh",
          "when": "view == coverlens.tree",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "CoverLens",
      "properties": {
        "coverlens.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable coverage decorations on startup"
        },
        "coverlens.coverageFiles": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "**/lcov.info",
            "**/lcov-report/lcov.info",
            "**/coverage/lcov.info",
            "**/coverage.lcov",
            "**/coverage.xml",
            "**/cov.xml",
            "**/coverage.cobertura.xml",
            "**/coverage-report.xml",
            "**/jacoco.xml",
            "**/jacoco-report.xml",
            "**/site/jacoco/jacoco.xml",
            "**/target/site/jacoco/jacoco.xml",
            "**/coverage.out",
            "**/*.coverprofile",
            "**/cover.out",
            "**/coverage.json",
            "**/coverage-final.json"
          ],
          "description": "Glob patterns to find coverage files. Add custom patterns if your tool outputs to a non-standard path."
        },
        "coverlens.excludePatterns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "**/node_modules/**",
            "**/.venv/**",
            "**/vendor/**",
            "**/dist/**"
          ],
          "description": "Glob patterns to exclude when searching for coverage files"
        },
        "coverlens.colors.covered": {
          "type": "string",
          "default": "",
          "description": "Color for covered lines (leave empty to use theme default green)"
        },
        "coverlens.colors.partial": {
          "type": "string",
          "default": "",
          "description": "Color for partially covered branch lines (leave empty to use theme default yellow)"
        },
        "coverlens.colors.uncovered": {
          "type": "string",
          "default": "",
          "description": "Color for uncovered lines (leave empty to use theme default red)"
        },
        "coverlens.decorationStyle": {
          "type": "string",
          "enum": [
            "border",
            "highlight"
          ],
          "default": "border",
          "description": "How to show coverage: 'border' = vertical bar on the left edge, 'highlight' = vertical bar + background fill"
        },
        "coverlens.overviewRuler": {
          "type": "boolean",
          "default": false,
          "description": "Show coverage colors in the scrollbar (overview ruler)"
        },
        "coverlens.onEdit": {
          "type": "string",
          "enum": ["hide", "dim", "keep"],
          "default": "dim",
          "description": "What to do with coverage when a file is edited: 'hide' = remove decorations, 'dim' = show faded, 'keep' = do nothing"
        },
        "coverlens.runOnSave": {
          "type": "string",
          "enum": ["off", "package", "all"],
          "default": "package",
          "description": "Auto-run tests on save: 'off' = disabled, 'package' = only affected package, 'all' = full test suite"
        },
        "coverlens.diffMode": {
          "type": "boolean",
          "default": false,
          "description": "Show coverage only for lines changed vs the base branch (git diff)"
        },
        "coverlens.diffBase": {
          "type": "string",
          "default": "HEAD",
          "description": "Base ref for diff mode (e.g. 'main', 'origin/main', 'HEAD~1')"
        },
        "coverlens.thresholds.low": {
          "type": "number",
          "default": 50,
          "description": "Coverage % below which the file is marked red in the tree"
        },
        "coverlens.thresholds.medium": {
          "type": "number",
          "default": 80,
          "description": "Coverage % below which the file is marked yellow in the tree"
        },
        "coverlens.testRunner.mode": {
          "type": "string",
          "enum": [
            "auto",
            "jest",
            "vitest",
            "pytest",
            "go",
            "cargo",
            "dotnet",
            "custom"
          ],
          "default": "auto",
          "description": "Test runner for 'Run Tests with Coverage' command"
        },
        "coverlens.testRunner.customCommand": {
          "type": "string",
          "default": "",
          "description": "Custom shell command to run tests with coverage (used when testRunner.mode = 'custom')"
        },
        "coverlens.monorepo.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Automatically detect and aggregate coverage from multiple packages in a monorepo"
        },
        "coverlens.monorepo.packages": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Override monorepo package roots (leave empty for auto-detection from package.json/pnpm-workspace.yaml)"
        },
        "coverlens.showDelta": {
          "type": "boolean",
          "default": true,
          "description": "Show coverage delta in status bar (vs session start or vs base in diff mode)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "test": "jest",
    "lint": "eslint src --ext ts"
  },
  "dependencies": {
    "chokidar": "^5.0.0",
    "fast-glob": "^3.3.3",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@types/vscode": "^1.110.0",
    "@types/xml2js": "^0.4.14",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vscode/vsce": "^3.7.1",
    "eslint": "^10.1.0",
    "jest": "^30.3.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.9",
    "ts-loader": "^9.5.7",
    "typescript": "^6.0.2",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.2"
  }
}
